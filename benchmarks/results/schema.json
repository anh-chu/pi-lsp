{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "pi-lsp benchmark result row",
  "type": "object",
  "required": [
    "run_id",
    "condition",
    "suite",
    "prompt_id",
    "cwd",
    "model",
    "thinking_level",
    "duration_ms",
    "turns",
    "tool_calls",
    "files_read",
    "quality_score"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "condition": { "type": "string", "enum": ["baseline", "treatment"] },
    "suite": { "type": "string", "enum": ["symbol", "refs", "ranking", "debug", "control", "compound"] },
    "prompt_id": { "type": "string" },
    "cwd": { "type": "string" },
    "timestamp": { "type": "string" },
    "model": { "type": "string" },
    "thinking_level": { "type": "string" },
    "input_tokens": { "type": ["number", "null"] },
    "output_tokens": { "type": ["number", "null"] },
    "cost": { "type": ["number", "null"] },
    "duration_ms": { "type": ["number", "null"] },
    "turns": { "type": ["number", "null"] },
    "tool_calls": { "type": ["number", "null"] },
    "tool_call_breakdown": { "type": "object", "additionalProperties": { "type": "number" } },
    "files_read": { "type": ["number", "null"] },
    "bytes_read": { "type": ["number", "null"] },
    "quality_score": { "type": "number", "minimum": 0, "maximum": 2 },
    "precision_score": { "type": ["number", "null"], "minimum": 0, "maximum": 2 },
    "first_useful_hop_score": { "type": ["number", "null"], "minimum": 0, "maximum": 2 },
    "route_correctness_score": { "type": ["number", "null"], "minimum": 0, "maximum": 2 },
    "control_cleanliness_score": { "type": ["number", "null"], "minimum": 0, "maximum": 2 },
    "wrong_first_tool": { "type": ["boolean", "null"] },
    "planner_route_correct": { "type": ["boolean", "null"] },
    "control_distraction": { "type": ["boolean", "null"] },
    "unnecessary_broad_read_penalty": { "type": ["number", "null"] },
    "first_tool": { "type": ["string", "null"] },
    "tool_family_sequence": { "type": ["array", "null"], "items": { "type": "string" } },
    "answer_text": { "type": ["string", "null"] },
    "session_path": { "type": ["string", "null"] },
    "treatment_usage_class": {
      "type": ["string", "null"],
      "enum": ["direct_adoption", "treatment_context_only", "treatment_loaded_but_unused", null]
    },
    "treatment_direct_adoption_calls": { "type": ["number", "null"] },
    "treatment_context_calls": { "type": ["number", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
